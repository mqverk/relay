{
  "port": 3000,
  "origin": "http://dummyjson.com",
  "ttl": "60s",
  "stale_while_revalidate": "30s",
  "stale_if_error": "5m",
  "cache_max_entries": 5000,
  "cache_max_entry_bytes": 1048576,
  "cache_max_bytes": 536870912,
  "cache_methods": ["GET"],
  "cache_bypass_paths": ["/auth", "/admin"],
  "cache_bypass_headers": ["Authorization"],
  "request_timeout": "30s",
  "dial_timeout": "10s",
  "idle_conn_timeout": "90s",
  "response_header_timeout": "15s",
  "max_response_header_bytes": 1048576,
  "max_idle_conns": 512,
  "max_idle_conns_per_host": 128,
  "max_conns_per_host": 256,
  "retry_count": 2,
  "retry_backoff": "100ms",
  "log_level": "info",
  "debug": false,
  "metrics_path": "/_relay/metrics",
  "admin_prefix": "/_relay",
  "rate_limit_rps": 200,
  "rate_limit_burst": 400
}
